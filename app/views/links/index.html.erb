<div class="min-h-screen bg-[#050505] text-white">
  <div class="lg:grid lg:grid-cols-[280px_1fr] lg:min-h-screen">
    
    <!-- Sidebar -->
    <aside class="hidden lg:flex flex-col border-r border-white/10 bg-[#0A0A0A] px-6 py-8">
      <div class="mb-12 flex items-center gap-3 border-b border-white/10 pb-8">
        <div class="flex h-12 w-12 items-center justify-center rounded-3xl bg-violet-500/10 text-violet-200 shadow-[0_12px_40px_rgba(139,92,246,0.16)]">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="h-6 w-6">
            <path d="M12 2l3.5 7.5L22 10l-5 4.8L18.5 22 12 18.7 5.5 22 7 14.8 2 10l6.5-0.5L12 2z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm uppercase tracking-[0.35em] text-violet-300/80">BioDiamante</p>
          <h2 class="text-xl font-semibold tracking-tight text-white">Admin</h2>
        </div>
      </div>

      <nav class="space-y-1 text-sm font-semibold">
        <%= link_to "Dashboard", "#", class: "group flex items-center rounded-3xl px-4 py-3 text-white/70 hover:bg-white/5 hover:text-white" %>
        <%= link_to "Meus Links", links_path, class: "group flex items-center rounded-3xl px-4 py-3 bg-white/5 text-white" %>
      </nav>

      <div class="mt-auto pt-8">
        <%= link_to "Sair", logout_path, method: :delete, class: "rounded-3xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white/80 hover:bg-red-500/10" %>
      </div>
    </aside>

    <!-- Main -->
    <main class="px-6 py-8 lg:px-10">

      <!-- Header -->
      <div class="mb-8 rounded-[2.5rem] border border-white/10 bg-[#09090b]/95 p-8">
        <div class="flex justify-between items-center">
          <div>
            <h1 class="text-4xl font-semibold">Meus Links</h1>
            <p class="text-sm text-white/60 mt-2">Arraste para reordenar</p>
          </div>
          <%= link_to "+ Novo Link", new_link_path, class: "bg-violet-500 px-5 py-3 rounded-xl" %>
        </div>
      </div>

      <% if @links.present? %>

        <!-- LISTA COM DRAG -->
        <div id="links-list" class="grid gap-5">
          <% @links.each do |link| %>

            <div class="link-item rounded-2xl border border-white/10 bg-[#0d0d11] p-6 cursor-move"
                 data-id="<%= link.id %>">

              <div class="flex justify-between">
                <div>
                  <h2 class="text-lg font-semibold">
                    <%= link.title.presence || "Link ##{link.id}" %>
                  </h2>
                  <p class="text-sm text-white/50 truncate">
                    <%= link.url %>
                  </p>
                </div>

                <div class="text-right">
                  <div class="text-sm text-violet-300">
                    <%= link.clicks || 0 %> cliques
                  </div>

                  <div class="text-sm">
                    <%= link.active ? "Ativo" : "Inativo" %>
                  </div>
                </div>
              </div>

              <div class="mt-4 flex gap-3">
                <%= link_to "Editar", edit_link_path(link), class: "px-4 py-2 bg-white/5 rounded-xl" %>
                <%= button_to "Excluir", link_path(link), method: :delete, class: "px-4 py-2 bg-red-500/20 rounded-xl" %>
              </div>

            </div>

          <% end %>
        </div>

      <% else %>
        <p class="text-center text-white/50">Nenhum link ainda</p>
      <% end %>

    </main>
  </div>
</div>

<!-- SORTABLE -->
<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const el = document.getElementById("links-list");

  if (el) {
    Sortable.create(el, {
      animation: 150,

      onEnd: function () {
        let ids = [];

        document.querySelectorAll(".link-item").forEach((item, index) => {
          ids.push({
            id: item.dataset.id,
            position: index + 1
          });
        });

        fetch("/links/sort", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content
          },
          body: JSON.stringify({ links: ids })
        });
      }
    });
  }
});
</script>