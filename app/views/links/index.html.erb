<div class="min-h-screen bg-[#050505] text-white">
  <div class="lg:grid lg:grid-cols-[280px_1fr] lg:min-h-screen">
    <aside class="hidden lg:flex flex-col border-r border-white/10 bg-[#0A0A0A] px-6 py-8">
      <div class="mb-12 flex items-center gap-3 border-b border-white/10 pb-8">
        <div class="flex h-12 w-12 items-center justify-center rounded-3xl bg-violet-500/10 text-violet-200 shadow-[0_12px_40px_rgba(139,92,246,0.16)]">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="h-6 w-6"><path d="M12 2l3.5 7.5L22 10l-5 4.8L18.5 22 12 18.7 5.5 22 7 14.8 2 10l6.5-0.5L12 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div>
          <p class="text-sm uppercase tracking-[0.35em] text-violet-300/80">BioDiamante</p>
          <h2 class="text-xl font-semibold tracking-tight text-white">Admin</h2>
        </div>
      </div>

      <nav class="space-y-1 text-sm font-semibold">
        <%= link_to "Dashboard", "#", class: "group flex items-center rounded-3xl px-4 py-3 text-white/70 transition hover:bg-white/5 hover:text-white" %>
        <%= link_to "Meus Links", links_path, class: "group flex items-center rounded-3xl px-4 py-3 bg-white/5 text-white" %>
        <%= link_to "Análises", "#", class: "group flex items-center rounded-3xl px-4 py-3 text-white/70 transition hover:bg-white/5 hover:text-white" %>
        <%= link_to "Configurações", "#", class: "group flex items-center rounded-3xl px-4 py-3 text-white/70 transition hover:bg-white/5 hover:text-white" %>
      </nav>

      <div class="mt-auto pt-8">
        <%= link_to "Sair", logout_path, method: :delete, class: "group flex items-center rounded-3xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white/80 transition hover:bg-red-500/10 hover:text-white" %>
      </div>
    </aside>

    <main class="px-6 py-8 lg:px-10">
      <div class="mb-8 flex flex-col gap-6 rounded-[2.5rem] border border-white/10 bg-[#09090b]/95 p-8 shadow-[0_30px_90px_rgba(0,0,0,0.45)] backdrop-blur-xl">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.35em] text-violet-300/80">Meus Links</p>
            <h1 class="text-4xl font-semibold tracking-tight text-white">Meus Links</h1>
            <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-300">Visão geral dos seus links mais importantes, com cliques, status e ações rápidas.</p>
          </div>
          <%= link_to "+ Novo Link", new_link_path, class: "inline-flex items-center justify-center rounded-[1.75rem] bg-gradient-to-r from-violet-500 via-fuchsia-500 to-purple-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-violet-500/20 transition duration-200 hover:-translate-y-0.5 hover:shadow-xl" %>
        </div>
      </div>

      <% if @links.present? %>
        <div class="grid gap-5">
          <% @links.each do |link| %>
            <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-[#0d0d11]/95 p-6 shadow-[0_25px_80px_rgba(0,0,0,0.25)] transition duration-200 hover:-translate-y-0.5">
              <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex items-start gap-4">
                  <div class="mt-1 flex h-12 w-12 items-center justify-center rounded-3xl bg-violet-500/15 text-violet-200 shadow-[0_10px_30px_rgba(139,92,246,0.16)]">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="h-6 w-6"><path d="M7 12l4-4 4 4M7 16l4-4 4 4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                  <div class="min-w-0">
                    <h2 class="text-lg font-semibold tracking-tight text-white"><%= link.title.presence || "Link ##{link.id}" %></h2>
                    <p class="mt-2 truncate text-sm text-white/50"><%= link.url %></p>
                  </div>
                </div>

                <div class="flex flex-col gap-3 sm:items-end sm:text-right">
                  <span class="inline-flex items-center rounded-full bg-violet-500/10 px-3 py-1 text-sm font-semibold text-violet-200">
                    <span class="mr-2 text-violet-300"><%= link.clicks || 0 %></span>cliques
                  </span>
                  <span class="inline-flex items-center gap-2 rounded-full bg-white/5 px-3 py-2 text-sm text-white/70 transition hover:bg-white/10">
                    <span class="text-sm text-white/60"><%= link.active ? "Ativo" : "Inativo" %></span>
                    <span class="h-3.5 w-3.5 rounded-full <%= link.active ? "bg-emerald-400" : "bg-white/40" %>"></span>
                  </span>
                </div>
              </div>

              <div class="mt-6 grid gap-3 border-t border-white/10 pt-5 sm:grid-cols-[1fr_auto] sm:items-center">
                <p class="text-sm leading-6 text-white/60"><%= link.title.presence || "Sem título" %></p>
                <div class="flex flex-wrap items-center justify-start gap-3 sm:justify-end">
                  <%= link_to "Editar", edit_link_path(link), class: "rounded-2xl border border-white/10 bg-white/5 px-4 py-2 text-sm text-white transition duration-200 hover:border-violet-400/30 hover:bg-violet-500/10" %>
                  <%= button_to "Excluir", link_path(link), method: :delete, data: { confirm: "Tem certeza que deseja excluir este link?" }, class: "rounded-2xl border border-white/10 bg-white/5 px-4 py-2 text-sm text-white transition duration-200 hover:border-red-400/30 hover:bg-red-500/10" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="rounded-[2rem] border border-dashed border-white/10 bg-[#0d0d11]/95 p-10 text-center shadow-[0_30px_90px_rgba(0,0,0,0.18)]">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-violet-500/10 text-violet-200 shadow-[0_15px_40px_rgba(139,92,246,0.18)]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="h-7 w-7"><path d="M12 5v14M5 12h14" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h2 class="mt-6 text-3xl font-semibold tracking-tight text-white">Nenhum link ainda</h2>
          <p class="mx-auto mt-3 max-w-xl text-sm text-white/60">Crie o primeiro link e comece a transformar sua bio em uma fonte de conversões de alto impacto.</p>
          <div class="mt-8">
            <%= link_to "+ Novo Link", new_link_path, class: "inline-flex items-center justify-center rounded-[1.75rem] bg-gradient-to-r from-violet-500 via-fuchsia-500 to-purple-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-violet-500/20 transition duration-200 hover:-translate-y-0.5 hover:shadow-xl" %>
          </div>
        </div>
      <% end %>
    </main>
  </div>
</div>
